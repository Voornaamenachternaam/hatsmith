    "cypress": "^14.4.1",
    "libsodium-wrappers": "^0.7.10",
    "marked": "18.0.2",
    "next": "^16.2.3",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
